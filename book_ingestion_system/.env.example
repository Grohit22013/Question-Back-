# ─── Vision LLM Provider ──────────────────────────────────
# Options: openai, gemini, anthropic
VISION_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ─── Google Gemini (uncomment if using) ──────────────────
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-1.5-pro

# ─── Anthropic (uncomment if using) ─────────────────────
# ANTHROPIC_API_KEY=your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── PostgreSQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=question_bank
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Pipeline Settings ──────────────────────────────────
BATCH_SIZE=1000
PARALLEL_WORKERS=4
MAX_RETRIES=3
PDF_DPI=200

# ─── Page Ranges ────────────────────────────────────────
QUESTION_START_PAGE=1
QUESTION_END_PAGE=926
ANSWER_KEY_START_PAGE=0
ANSWER_KEY_END_PAGE=0
